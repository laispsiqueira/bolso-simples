rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'laispsiqueira@gmail.com';
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /transactions/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /category_rules/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /simulations/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /processed_files/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /file_patterns/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /processing_history/{id} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
